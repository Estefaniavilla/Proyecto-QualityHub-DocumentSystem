@model IEnumerable<QualityHub_DocumentSystem.Models.Documento>
@{
    ViewData["Title"] = "Control de Documentos";
    int roleID = ViewBag.UserRole ?? 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
    }

    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        background: #ffffff;
    }

    .table-premium th {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        border: none;
        padding: 16px;
    }

    .table-premium td {
        padding: 16px;
        vertical-align: middle;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .btn-action {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        transition: all 0.2s ease;
        margin-right: 4px;
        text-decoration: none;
        cursor: pointer;
    }

    .file-icon-box {
        font-size: 1.5rem;
        margin-right: 12px;
    }

    .icon-pdf {
        color: #ef4444;
    }

    .icon-word {
        color: #3b82f6;
    }

    .icon-excel {
        color: #10b981;
    }

    .pulse-warning {
        animation: customPulse 2s infinite;
    }

    @@keyframes customPulse {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5);
        }

        70% {
            transform: scale(1.03);
            box-shadow: 0 0 0 10px rgba(245, 158, 11, 0);
        }

        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(245, 158, 11, 0);
        }
    }

    .timeline-container::before {
        content: '';
        position: absolute;
        left: 20px;
        top: 0;
        height: 100%;
        width: 2px;
        background: #e2e8f0;
    }

    .timeline-item {
        position: relative;
        padding-left: 50px;
        margin-bottom: 1.5rem;
    }

    .timeline-icon {
        position: absolute;
        left: 10px;
        top: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 0 0 2px #e2e8f0;
    }

    .timeline-content {
        background: #f8fafc;
        border-radius: 10px;
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
    }

    .timeline-date {
        font-size: 0.75rem;
        color: #64748b;
        font-weight: 600;
    }

    .timeline-action {
        font-size: 0.9rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .timeline-user {
        font-size: 0.8rem;
        color: #475569;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .timeline-comment {
        font-size: 0.85rem;
        color: #334155;
        margin-top: 8px;
        background: #ffffff;
        padding: 8px;
        border-radius: 6px;
        border-left: 3px solid #3b82f6;
    }

    /* Estilos Premium del Buscador y Snippets MongoDB */
    .search-bar-container {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 25px rgba(0, 0, 0, 0.04);
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }
    .search-bar-container:focus-within {
        box-shadow: 0 4px 30px rgba(59, 130, 246, 0.12);
        border-color: #3b82f6;
    }
    .input-search-premium {
        border: none;
        outline: none;
        box-shadow: none !important;
        font-size: 1.05rem;
    }
    .filter-badge {
        background: #f1f5f9;
        color: #475569;
        font-weight: 500;
        font-size: 0.85rem;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }
    .filter-badge:hover {
        background: #e2e8f0;
    }
    .snippet-match {
        font-size: 0.82rem;
        color: #475569;
        background: #f8fafc;
        border-left: 3px solid #cbd5e1;
        padding: 6px 12px;
        border-radius: 4px;
        margin-top: 6px;
        line-height: 1.4;
    }
    .snippet-match mark {
        background-color: rgba(253, 224, 71, 0.6);
        color: #1e293b;
        padding: 0 2px;
        border-radius: 2px;
        font-weight: 600;
    }
    .metadata-tag {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 4px;
        background: #e0f2fe;
        color: #0369a1;
        margin-right: 4px;
        display: inline-block;
    }
    .paginator-btn {
        min-width: 38px;
        height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        transition: all 0.2s;
    }
</style>

<input type="file" id="globalFileUploader" style="display: none;" onchange="procesarArchivoSeleccionado(this)" />

<div class="container-fluid px-0 py-2">
    @if (roleID == 1)
    {
        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Creador" asp-controller="Home" class="btn btn-primary d-inline-flex align-items-center gap-2 shadow-sm fw-semibold py-2 px-3" style="border-radius: 10px;">
                <i class="bi bi-plus-circle-fill"></i> Ir al Panel de Creación de Documentos
            </a>
        </div>
    }

    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1" style="font-size: 1.75rem; letter-spacing: -0.5px;">Control de Versiones y Distribución</h2>
        <p class="text-muted small mb-0">Gestión documental centralizada del ecosistema QualityHub</p>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert"><i class="fa-solid fa-circle-check me-2"></i> @TempData["Mensaje"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert"><i class="fa-solid fa-circle-xmark me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- BUSCADOR PREMIUM DE METADATOS Y ARCHIVOS (MONGODB) -->
    <div class="search-bar-container p-3 mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-lg-6 col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="fa-solid fa-magnifying-glass fs-5"></i></span>
                    <input type="text" id="inputBuscarMongo" class="form-control input-search-premium" placeholder="Buscar palabras clave, códigos o metadatos de MongoDB..." onkeyup="evaluarBusqueda(event)">
                </div>
            </div>
            <div class="col-lg-2 col-md-3">
                <select id="selectFiltroExt" class="form-select border-1" style="border-radius: 8px;" onchange="buscarMongo(1)">
                    <option value="">-- Todos los formatos --</option>
                    <option value="PDF">PDF (.pdf)</option>
                    <option value="DOCX">Word (.docx)</option>
                    <option value="XLSX">Excel (.xlsx)</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-4">
                <input type="date" id="inputFiltroFecha" class="form-control border-1" style="border-radius: 8px;" onchange="buscarMongo(1)" title="Filtrar por última modificación">
            </div>
            <div class="col-lg-2 col-md-12 d-flex gap-2">
                <button type="button" class="btn btn-primary w-100 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-radius: 8px;" onclick="buscarMongo(1)">
                    <i class="fa-solid fa-filter"></i> Buscar
                </button>
                <button type="button" class="btn btn-light border" style="border-radius: 8px;" onclick="limpiarBuscador()" title="Restaurar lista original">
                    <i class="fa-solid fa-arrow-rotate-left"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- CONTENEDOR DE TABLAS ESTATICAS (VISTA ORIGINAL RAZOR) -->
    <div class="card custom-card" id="cardOriginalRazor">
        <div class="card-body p-0">
            <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center" style="border-radius: 16px 16px 0 0;">
                <ul class="nav nav-pills card-header-pills" id="docTabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active fw-bold small text-uppercase py-2 px-3" id="nuevos-tab" data-bs-toggle="tab" data-bs-target="#nuevosPanel" type="button" style="border-radius: 8px;"><i class="bi bi-sparkles text-warning me-1"></i> Nuevos / Recientes</button></li>
                    <li class="nav-item"><button class="nav-link fw-bold small text-uppercase py-2 px-3 ms-2" id="todos-tab" data-bs-toggle="tab" data-bs-target="#todosPanel" type="button" style="border-radius: 8px;"><i class="bi bi-folder2-open me-1"></i> Todos los Documentos</button></li>
                </ul>
            </div>

            <div class="tab-content" id="docTabsContent">
                <div class="tab-pane fade show active" id="nuevosPanel">
                    <div class="table-responsive">
                        <table class="table table-premium mb-0">
                            <thead><tr><th style="width: 15%;">CÓDIGO</th><th style="width: 35%;">NOMBRE DEL ARCHIVO</th><th style="width: 10%;" class="text-center">VERSIÓN</th><th style="width: 15%;">ESTADO</th><th class="text-center" style="width: 25%;">ACCIONES</th></tr></thead>
                            <tbody>
                                @{
                                    var tieneNuevos = false;
                                }
                                @foreach (var doc in ViewBag.Apartados)
                                {
                                    if (string.IsNullOrEmpty(doc.ArchivoFisico) || doc.Estado == "Creado" || doc.Estado == "Borrador" || doc.Estado == "Pendiente Revisión" || doc.Estado == "En Revisión" || doc.Estado == "Rechazado")
                                    {
                                        tieneNuevos = true;
                                        <tr>
                                            <td class="fw-bold text-primary small align-middle">@doc.Codigo</td>
                                            <td class="align-middle"><div class="d-flex align-items-center">@Html.Raw(ObtenerIconoExtension(doc.Extension))<div><span class="fw-semibold d-block">@doc.Nombre</span><small class="text-muted opacity-75" style="font-size: 0.72rem;">Reciente</small></div></div></td>
                                            <td class="text-center align-middle"><span class="badge bg-light text-dark border fw-bold px-2 py-1">@doc.Version</span></td>
                                            <td class="align-middle"><span class="badge bg-@(doc.Estado == "Rechazado" ? "danger" : "info") fw-bold px-2 py-1 shadow-sm text-dark">@(string.IsNullOrEmpty(doc.Estado) ? "Borrador" : doc.Estado)</span></td>
                                            <td class="text-center align-middle">@Html.Raw(ObtenerAccionesFila(doc, roleID))</td>
                                        </tr>
                                    }
                                }
                                @if (!tieneNuevos)
                                {
                                    <tr><td colspan="5" class="text-center p-5 text-muted"><i class="bi bi-journal-check fs-1 d-block mb-2 text-success opacity-50"></i><span class="fw-semibold">No hay documentos nuevos pendientes.</span></td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="todosPanel">
                    <div class="table-responsive">
                        <table class="table table-premium mb-0">
                            <thead><tr><th style="width: 15%;">CÓDIGO</th><th style="width: 35%;">NOMBRE DEL ARCHIVO</th><th style="width: 10%;" class="text-center">VERSIÓN</th><th style="width: 15%;">ESTADO</th><th class="text-center" style="width: 25%;">ACCIONES</th></tr></thead>
                            <tbody>
                                @foreach (var doc in ViewBag.Apartados)
                                {
                                    <tr>
                                        <td class="fw-bold text-secondary small align-middle">@doc.Codigo</td>
                                        <td class="align-middle"><div class="d-flex align-items-center">@Html.Raw(ObtenerIconoExtension(doc.Extension))<div><span class="fw-semibold d-block">@doc.Nombre</span></div></div></td>
                                        <td class="text-center align-middle"><span class="badge bg-light text-dark border fw-bold px-2 py-1">@doc.Version</span></td>
                                        <td class="align-middle"><span class="badge bg-@(doc.Estado == "En Revisión" || doc.Estado == "Pendiente Revisión" ? "warning text-dark" : doc.Estado == "Autorizado" ? "success" : doc.Estado == "Rechazado" ? "danger" : "secondary") fw-bold px-2 py-1 shadow-sm">@doc.Estado</span></td>
                                        <td class="text-center align-middle">@Html.Raw(ObtenerAccionesFila(doc, roleID))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CONTENEDOR DINÁMICO DE RESULTADOS DE BÚSQUEDA MONGO -->
    <div class="card custom-card d-none" id="cardResultadosMongo">
        <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center" style="border-radius: 16px 16px 0 0;">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold text-white shadow-sm" id="badgeTotalResultados">0 resultados</span>
                <span class="text-muted small">Búsqueda avanzada en metadatos y contenido MongoDB</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-premium mb-0">
                    <thead>
                        <tr>
                            <th style="width: 12%;">CÓDIGO</th>
                            <th style="width: 40%;">COINCIDENCIAS Y ARCHIVO</th>
                            <th style="width: 8%;" class="text-center">VERSIÓN</th>
                            <th style="width: 15%;">ESTADO</th>
                            <th class="text-center" style="width: 25%;">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyResultadosMongo">
                        <!-- Renderizado vía Javascript -->
                    </tbody>
                </table>
            </div>
            <!-- Paginador -->
            <div class="p-3 border-top d-flex justify-content-center" id="paginacionMongo"></div>
        </div>
    </div>
</div>

@functions {
    public string ObtenerIconoExtension(string ext)
    {
        string uExt = ext?.ToUpper() ?? "";
        if (uExt == "PDF" || uExt == ".PDF") return "<i class='fa-solid fa-file-pdf file-icon-box icon-pdf'></i>";
        if (uExt == "DOCX" || uExt == "DOC" || uExt == ".DOCX") return "<i class='fa-solid fa-file-word file-icon-box icon-word'></i>";
        if (uExt == "XLSX" || uExt == "XLS" || uExt == ".XLSX") return "<i class='fa-solid fa-file-excel file-icon-box icon-excel'></i>";
        return "<i class='fa-solid fa-file-lines file-icon-box text-secondary'></i>";
    }

    public string ObtenerAccionesFila(dynamic doc, int roleID)
    {
        string html = "<div class='dropdown d-inline-block'>";
        bool esProtegido = (roleID == 1 && (doc.Estado == "En Revisión" || doc.Estado == "Pendiente Revisión"));

        if (esProtegido) return "<button class='btn btn-light text-muted border border-secondary shadow-sm fw-bold px-3' disabled style='border-radius: 8px;'><i class='fa-solid fa-lock me-1'></i> Protegido</button>";

        html += "<button class='btn btn-danger btn-sm dropdown-toggle shadow-sm fw-bold px-3' type='button' data-bs-toggle='dropdown' style='border-radius: 8px;'><i class='fa-solid fa-bolt me-1'></i> Acciones</button>";
        html += "<ul class='dropdown-menu shadow border-0' style='border-radius: 12px; font-size: 0.9rem;'>";

        if (!string.IsNullOrEmpty(doc.ArchivoFisico))
        {
            html += $"<li><button type='button' class='dropdown-item py-2 text-success fw-medium btn-abrir-visor' data-url='{doc.RutaWeb}' data-nombre='{doc.Nombre}'><i class='fa-solid fa-eye me-2'></i> Ver Documento</button></li>";
            html += $"<li><a href='{doc.RutaWeb}' class='dropdown-item py-2 text-primary fw-medium' download><i class='fa-solid fa-download me-2'></i> Descargar Archivo</a></li><li><hr class='dropdown-divider'></li>";
        }

        if (roleID == 1) // CREADOR
        {
            if (string.IsNullOrEmpty(doc.ArchivoFisico)) html += $"<li><button type='button' class='dropdown-item py-2 fw-bold text-primary' onclick=\"solicitarArchivoFisico('{doc.Id}', '{doc.Nombre}')\"><i class='fa-solid fa-upload me-2'></i> Cargar Archivo</button></li>";
            else html += $"<li><button type='button' class='dropdown-item py-2 fw-medium text-warning' onclick=\"abrirEditor('{doc.Id}', '{doc.Nombre}')\"><i class='fa-solid fa-pen-to-square me-2'></i> Subir Nueva Versión</button></li>";
        }
        else if (roleID == 2) // REVISADOR
        {
            if (doc.Estado == "En Revisión" || doc.Estado == "Pendiente Revisión")
                html += $"<li><button type='button' class='dropdown-item py-2 fw-bold text-warning pulse-warning' onclick=\"abrirModalRevision('{doc.Id}', '{doc.Nombre}', '{doc.Codigo}', '{doc.Version}')\"><i class='fa-solid fa-check-double me-2'></i> Evaluar Documento</button></li>";
            else
                html += $"<li><button type='button' class='dropdown-item py-2 fw-medium text-info' onclick=\"verHistorialDocumento('{doc.Id}', '{doc.Nombre}')\"><i class='fa-solid fa-clock-rotate-left me-2'></i> Ver Historial</button></li>";
        }
        html += "</ul></div>"; return html;
    }
}

<!-- MODALES -->
<div class="modal fade" id="modalVisorDocumental" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg" style="border-radius: 16px; border: none; overflow: hidden;">
            <div class="modal-header bg-dark text-white p-3"><h5 class="modal-title fw-bold"><i class="fa-solid fa-file-magnifying-glass text-info me-2"></i> Vista Previa</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-0" style="height: 75vh; background-color: #e2e8f0;"><iframe id="iframeVisorDocumento" src="" style="width: 100%; height: 100%; border: none;"></iframe></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalRevision" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow" style="border-radius: 16px; border: none;">
            <div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold"><i class="fa-solid fa-envelope-open-text text-warning me-2"></i>Panel de Dictamen</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <form asp-action="ProcesarRevision" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" id="revDocumentoId" name="documentoId" />
                    <input type="hidden" id="revVersionId" name="versionId" value="0" />
                    <div class="card bg-light border-0 mb-3" style="border-radius: 10px;">
                        <div class="card-body p-3">
                            <h6 class="fw-bold text-secondary text-uppercase mb-3" style="font-size: 0.75rem;">Detalles</h6>
                            <div class="row g-2 mb-2"><div class="col-4 text-muted small fw-semibold">Doc:</div><div class="col-8 small fw-bold text-dark" id="revDocumentoNombreTexto"></div></div>
                            <div class="row g-2 mb-2"><div class="col-4 text-muted small fw-semibold">Versión:</div><div class="col-8 small"><span class="badge bg-primary px-2" id="revVersionTexto"></span></div></div>
                            <div class="row g-2 mb-2"><div class="col-4 text-muted small fw-semibold">Creador:</div><div class="col-8 small fw-bold text-info" id="revCreador">Cargando...</div></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Dictamen:</label>
                        <select name="dictamen" class="form-select border-2 fw-medium" required>
                            <option value="" disabled selected>-- Seleccione --</option>
                            <option value="Revisado">🟢 Aprobar (A Autorizador)</option>
                            <option value="Rechazado">🔴 Rechazar (A Creador)</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold">Comentarios:</label>
                        <textarea name="comentarios" class="form-control border-2" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light p-3">
                    <button type="button" class="btn btn-outline-secondary fw-semibold px-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-warning text-dark fw-bold px-4 shadow-sm"><i class="fa-solid fa-paper-plane me-1"></i> Registrar Revisión</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalModificar" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content border-0 shadow-lg" style="border-radius: 16px;"><div class="modal-header border-0 pb-0"><h4 class="modal-title fw-bold w-100 text-center text-dark" id="modificarTitulo">Modificar: Documento</h4><button type="button" class="btn-close position-absolute end-0 top-0 m-3" data-bs-dismiss="modal"></button></div><div class="modal-body px-4 pt-3 pb-4"><form id="formModificar" enctype="multipart/form-data"><input type="hidden" name="documentoId" id="modificarDocId"><div class="mb-3"><label class="form-label fw-bold text-danger fs-6"><i class="fa-solid fa-server me-2"></i>Sugerencia API (PHP):</label><textarea class="form-control bg-light" id="modificarSugerenciaPHP" rows="3" readonly style="border-radius: 8px; resize: none;"></textarea></div><div class="mb-3"><label class="form-label fw-bold fs-6" style="color: #ffb703;"><i class="fa-solid fa-user-tie me-2"></i>Mensaje del Revisador:</label><input type="text" class="form-control bg-light" id="modificarMensajeRevisador" readonly style="border-radius: 8px;"></div><div class="mb-4"><label class="form-label fw-bold text-dark fs-6"><i class="fa-solid fa-upload me-2"></i>Sube el documento corregido:</label><input type="file" class="form-control border-primary shadow-sm" name="archivoFisico" id="modificarArchivo" required style="border-radius: 8px;"></div><div class="d-flex justify-content-center gap-3"><button type="button" onclick="guardarCorreccion()" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 8px; font-size: 1rem;"><i class="fa-solid fa-cloud-arrow-up me-2"></i>Guardar Corrección</button><button type="button" class="btn btn-secondary px-4 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 8px; font-size: 1rem;">Cancelar</button></div></form></div></div></div></div>

<div class="modal fade" id="modalHistorial" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-dialog-scrollable"><div class="modal-content border-0 shadow-lg" style="border-radius: 16px;"><div class="modal-header border-0 bg-white p-4 pb-2"><h4 class="modal-title fw-bold text-dark w-100 text-center" id="historialTitulo">Historial de Documento</h4><button type="button" class="btn-close position-absolute end-0 top-0 m-3" data-bs-dismiss="modal"></button></div><div class="modal-body p-4 pt-2"><div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom"><span class="badge bg-dark rounded-pill px-3 py-2 fs-6 shadow-sm" id="historialEstado">Estado</span><span class="badge bg-primary rounded-pill px-3 py-2 fs-6 shadow-sm" id="historialVersion">v1.0</span></div><div class="timeline-container position-relative" id="historialTimeline"></div></div><div class="modal-footer border-0 d-flex justify-content-center pb-4"><button type="button" class="btn px-5 py-2 fw-bold text-white shadow-sm" data-bs-dismiss="modal" style="border-radius: 10px; background-color: #6366f1;">Cerrar Historial</button></div></div></div></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const botonesVisor = document.querySelectorAll('.btn-abrir-visor');
        const campoIframe = document.getElementById('iframeVisorDocumento');
        const instanciaModal = new bootstrap.Modal(document.getElementById('modalVisorDocumental'));

        botonesVisor.forEach(btn => {
            btn.addEventListener('click', function () {
                const url = this.getAttribute('data-url');
                if(url.toLowerCase().endsWith('.pdf')) { campoIframe.src = url; }
                else { campoIframe.src = "https://view.officeapps.live.com/op/embed.aspx?src=" + encodeURIComponent(window.location.origin + url); }
                instanciaModal.show();
            });
        });
        document.getElementById('modalVisorDocumental').addEventListener('hidden.bs.modal', function () { campoIframe.src = ""; });
    });

    function abrirModalRevision(id, nombre, codigo, version) {
        document.getElementById('revDocumentoId').value = id;
        document.getElementById('revDocumentoNombreTexto').innerText = `${codigo} - ${nombre}`;
        document.getElementById('revVersionTexto').innerText = version || 'v1.0';
        document.getElementById('revCreador').innerHTML = "<i class='fa-solid fa-spinner fa-spin text-primary me-1'></i> Cargando...";
        new bootstrap.Modal(document.getElementById('modalRevision')).show();

        fetch('/Home/ObtenerHistorialDocumento?documentoId=' + id)
        .then(res => res.json())
        .then(data => {
            document.getElementById('revCreador').innerHTML = "<i class='fa-solid fa-user text-info me-1'></i> " + (data.creador || "Creador Inicial");
        }).catch(err => {
            document.getElementById('revCreador').innerHTML = "<i class='fa-solid fa-user text-warning me-1'></i> Creador Inicial";
        });
    }

    function solicitarArchivoFisico(id, nombre) { documentoIdParaCarga = id; document.getElementById('globalFileUploader').click(); }

    function procesarArchivoSeleccionado(inputElement) {
        if (inputElement.files.length === 0) return;
        Swal.fire({
            title: 'Subiendo Documento', didOpen: () => {
                Swal.showLoading();
                const formData = new FormData(); formData.append("documentoId", documentoIdParaCarga); formData.append("archivoFisico", inputElement.files[0]);
                fetch('/Home/CargarArchivo', { method: 'POST', body: formData })
                .then(r => r.json()).then(d => { if(d.success === false) Swal.fire('Error', d.message, 'error'); else window.location.reload(); });
            }
        });
    }

    function abrirEditor(id, nombre) {
        document.getElementById('modificarDocId').value = id; document.getElementById('modificarTitulo').innerText = "Modificar: " + nombre;
        fetch('/Home/ObtenerSugerencias?documentoId=' + id).then(res => res.json()).then(data => {
            document.getElementById('modificarSugerenciaPHP').value = data.sugerenciaPHP || "Sin sugerencias pendientes.";
            document.getElementById('modificarMensajeRevisador').value = data.mensajeRevisador || "Sin comentarios.";
            new bootstrap.Modal(document.getElementById('modalModificar')).show();
        });
    }

    function guardarCorreccion() {
        fetch('/Home/CargarArchivo', { method: 'POST', body: new FormData(document.getElementById('formModificar')) })
        .then(r => r.json()).then(d => { if(d.success) location.reload(); else alert('Error: ' + d.message); });
    }

    function verHistorialDocumento(id, nombre) {
        document.getElementById('historialTitulo').innerText = "Historial: " + nombre;
        document.getElementById('historialTimeline').innerHTML = "<div class='text-center py-4'><i class='fa-solid fa-spinner fa-spin fa-2x text-primary'></i></div>";
        new bootstrap.Modal(document.getElementById('modalHistorial')).show();
        fetch('/Home/ObtenerHistorialDocumento?documentoId=' + id).then(res => res.json()).then(data => {
            document.getElementById('historialEstado').innerText = "Estado actual: " + data.estado;
            document.getElementById('historialVersion').innerText = "v" + data.version.replace('v','');
            let html = "";
            data.historial.forEach(log => {
                let color = "primary"; let icon = "fa-check";
                if(log.accion.includes("Rechazado")) { color = "danger"; icon = "fa-xmark"; }
                else if(log.accion.includes("Autorizado")) { color = "success"; icon = "fa-check-double"; }
                html += `<div class="timeline-item"><div class="timeline-icon bg-${color} d-flex justify-content-center align-items-center text-white"><i class="fa-solid ${icon}" style="font-size: 0.6rem;"></i></div><div class="timeline-content"><div class="d-flex justify-content-between align-items-center mb-1"><span class="timeline-action text-${color}">${log.accion}</span><span class="timeline-date">${log.fecha}</span></div><div class="timeline-user"><i class="fa-solid fa-user-circle"></i> ${log.usuario}</div><div class="timeline-comment">${log.comentario}</div></div></div>`;
            });
            document.getElementById('historialTimeline').innerHTML = html || "<div class='text-center text-muted'>Sin historial.</div>";
        });
    }

    // ============================================================
    // MOTOR DE BÚSQUEDA MONGODB - INTEGRACIÓN CSHTML
    // ============================================================
    const CURRENT_ROLE_ID = @roleID;
    let paginaActual = 1;
    let busquedaTimer = null;

    // Evalúa si hay texto para disparar búsqueda automática al escribir
    function evaluarBusqueda(event) {
        clearTimeout(busquedaTimer);
        const q = document.getElementById('inputBuscarMongo').value.trim();
        if (q.length === 0) {
            limpiarBuscador();
            return;
        }
        if (q.length < 2) return;
        busquedaTimer = setTimeout(() => buscarMongo(1), 400);
    }

    // Función principal que consulta la API de búsqueda MongoDB
    function buscarMongo(pagina) {
        paginaActual = pagina || 1;
        const q    = document.getElementById('inputBuscarMongo').value.trim();
        const ext  = document.getElementById('selectFiltroExt').value;
        const fecha = document.getElementById('inputFiltroFecha').value;

        const params = new URLSearchParams({ q, ext, fecha, pagina: paginaActual, porPagina: 10 });

        // Mostrar spinner en tabla de resultados
        document.getElementById('cardOriginalRazor').classList.add('d-none');
        document.getElementById('cardResultadosMongo').classList.remove('d-none');
        document.getElementById('tbodyResultadosMongo').innerHTML =
            `<tr><td colspan="5" class="text-center py-5">
                <i class="fa-solid fa-spinner fa-spin fa-2x text-primary mb-2 d-block"></i>
                <span class="text-muted">Buscando en MongoDB...</span>
             </td></tr>`;

        fetch('/Home/BuscarDocumentosMongo?' + params.toString())
            .then(res => res.json())
            .then(data => {
                const docs = data.resultados || [];
                const total = data.total || 0;
                const totalPags = data.totalPaginas || 1;

                document.getElementById('badgeTotalResultados').textContent =
                    total === 1 ? '1 resultado' : `${total} resultados`;

                if (docs.length === 0) {
                    document.getElementById('tbodyResultadosMongo').innerHTML =
                        `<tr><td colspan="5" class="text-center p-5 text-muted">
                            <i class="bi bi-search fs-1 d-block mb-2 opacity-50"></i>
                            <span class="fw-semibold">No se encontraron documentos con esos criterios.</span>
                         </td></tr>`;
                    document.getElementById('paginacionMongo').innerHTML = '';
                    return;
                }

                let tbody = '';
                docs.forEach(doc => { tbody += renderizarFilaMongo(doc); });
                document.getElementById('tbodyResultadosMongo').innerHTML = tbody;

                // Paginación
                renderizarPaginacion(paginaActual, totalPags);

                // Reasignar evento del visor a los nuevos botones
                document.querySelectorAll('#tbodyResultadosMongo .btn-abrir-visor-mongo').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const url = this.getAttribute('data-url');
                        const iframe = document.getElementById('iframeVisorDocumento');
                        if (url.toLowerCase().endsWith('.pdf')) { iframe.src = url; }
                        else { iframe.src = "https://view.officeapps.live.com/op/embed.aspx?src=" + encodeURIComponent(window.location.origin + url); }
                        new bootstrap.Modal(document.getElementById('modalVisorDocumental')).show();
                    });
                });
            })
            .catch(err => {
                document.getElementById('tbodyResultadosMongo').innerHTML =
                    `<tr><td colspan="5" class="text-center py-5 text-danger">
                        <i class="fa-solid fa-circle-xmark fa-2x d-block mb-2"></i>
                        Error al conectar con MongoDB. Verifica que el contenedor esté activo.
                     </td></tr>`;
                console.error('Error búsqueda MongoDB:', err);
            });
    }

    // Renderiza una fila dinámica de resultado de MongoDB con snippet + acciones por rol
    function renderizarFilaMongo(doc) {
        const iconos = {
            'PDF':  "<i class='fa-solid fa-file-pdf file-icon-box icon-pdf'></i>",
            'DOCX': "<i class='fa-solid fa-file-word file-icon-box icon-word'></i>",
            'DOC':  "<i class='fa-solid fa-file-word file-icon-box icon-word'></i>",
            'XLSX': "<i class='fa-solid fa-file-excel file-icon-box icon-excel'></i>",
            'XLS':  "<i class='fa-solid fa-file-excel file-icon-box icon-excel'></i>"
        };
        const ext = (doc.extension || '').toUpperCase().replace('.', '');
        const icono = iconos[ext] || "<i class='fa-solid fa-file-lines file-icon-box text-secondary'></i>";

        const snippet = doc.snippet
            ? `<div class="snippet-match mt-1">${doc.snippet}</div>`
            : '';

        const tags = [];
        if (doc.author)   tags.push(`<span class="metadata-tag"><i class="fa-solid fa-user" style="font-size:0.65rem;"></i> ${doc.author}</span>`);
        if (doc.company)  tags.push(`<span class="metadata-tag"><i class="fa-solid fa-building" style="font-size:0.65rem;"></i> ${doc.company}</span>`);
        const tagsHtml = tags.length ? `<div class="mt-1">${tags.join('')}</div>` : '';

        const estadoBadge = (() => {
            const e = doc.estado || 'Desconocido';
            if (e === 'Vigente' || e === 'Autorizado') return `<span class="badge bg-success fw-bold px-2 py-1">${e}</span>`;
            if (e.includes('Revisión') || e.includes('Pendiente')) return `<span class="badge bg-warning text-dark fw-bold px-2 py-1">${e}</span>`;
            if (e === 'Rechazado') return `<span class="badge bg-danger fw-bold px-2 py-1">${e}</span>`;
            return `<span class="badge bg-secondary fw-bold px-2 py-1">${e}</span>`;
        })();

        // Acciones adaptadas al rol del usuario actual
        let accionesHtml = '';
        const rutaWeb = doc.rutaWeb || '';
        const tieneArchivo = rutaWeb && rutaWeb !== '';

        if (tieneArchivo) {
            accionesHtml += `<button type="button" class="btn btn-sm btn-outline-success me-1 btn-abrir-visor-mongo" data-url="${rutaWeb}" style="border-radius:8px;" title="Ver Documento">
                                <i class="fa-solid fa-eye"></i>
                             </button>
                             <a href="${rutaWeb}" class="btn btn-sm btn-outline-primary me-1" download style="border-radius:8px;" title="Descargar">
                                <i class="fa-solid fa-download"></i>
                             </a>`;
        }

        accionesHtml += `<button type="button" class="btn btn-sm btn-outline-info" style="border-radius:8px;" title="Ver Metadatos" onclick="mostrarMetadatosMongo('${doc.nombreFisico || ''}')">
                            <i class="fa-solid fa-database"></i>
                         </button>`;

        return `<tr>
            <td class="fw-bold text-secondary small align-middle">${doc.codigoIso || 'N/A'}</td>
            <td class="align-middle">
                <div class="d-flex align-items-start">
                    <div style="min-width:30px; padding-top:2px;">${icono}</div>
                    <div>
                        <span class="fw-semibold d-block">${doc.nombre || doc.nombreFisico || 'Sin nombre'}</span>
                        ${tagsHtml}
                        ${snippet}
                    </div>
                </div>
            </td>
            <td class="text-center align-middle"><span class="badge bg-light text-dark border fw-bold px-2 py-1">${doc.version || 'N/A'}</span></td>
            <td class="align-middle">${estadoBadge}</td>
            <td class="text-center align-middle">${accionesHtml}</td>
        </tr>`;
    }

    // Renderiza los botones de paginación
    function renderizarPaginacion(actual, total) {
        if (total <= 1) { document.getElementById('paginacionMongo').innerHTML = ''; return; }
        let html = '';
        for (let i = 1; i <= total; i++) {
            html += `<button type="button" class="paginator-btn btn ${i === actual ? 'btn-primary' : 'btn-light border'} mx-1" onclick="buscarMongo(${i})">${i}</button>`;
        }
        document.getElementById('paginacionMongo').innerHTML = html;
    }

    // Muestra modal con los metadatos completos del documento desde MongoDB
    function mostrarMetadatosMongo(nombreFisico) {
        if (!nombreFisico) {
            Swal.fire('Sin metadatos', 'Este documento no tiene metadatos registrados en MongoDB.', 'info');
            return;
        }
        const modal = new bootstrap.Modal(document.getElementById('modalMetadatosMongo'));
        document.getElementById('metadatosBody').innerHTML =
            `<div class="text-center py-4"><i class="fa-solid fa-spinner fa-spin fa-2x text-primary"></i><p class="mt-2 text-muted">Cargando metadatos...</p></div>`;
        document.getElementById('metadatosTitulo').textContent = 'Metadatos: ' + nombreFisico;
        modal.show();

        fetch('/Home/ObtenerMetadatosMongo?archivo=' + encodeURIComponent(nombreFisico))
            .then(res => res.json())
            .then(data => {
                if (!data || data.error) {
                    document.getElementById('metadatosBody').innerHTML =
                        `<div class="alert alert-warning m-3"><i class="fa-solid fa-circle-exclamation me-2"></i>No se encontraron metadatos para este archivo.</div>`;
                    return;
                }
                const ignorar = ['_id', 'id', '__v'];
                let rows = '';
                for (const [k, v] of Object.entries(data)) {
                    if (ignorar.includes(k.toLowerCase())) continue;
                    const val = v !== null && v !== '' && v !== undefined ? String(v) : null;
                    if (!val) continue;
                    const label = k.replace(/_/g, ' ').replace(/([a-z])([A-Z])/g, '$1 $2');
                    rows += `<tr>
                        <td class="fw-semibold text-muted small" style="width:38%; text-transform:capitalize;">${label}</td>
                        <td class="small text-dark fw-medium">${val}</td>
                    </tr>`;
                }
                document.getElementById('metadatosBody').innerHTML = rows
                    ? `<table class="table table-sm table-hover mb-0">${rows}</table>`
                    : `<div class="text-center text-muted py-3">Sin campos con valores.</div>`;
            })
            .catch(() => {
                document.getElementById('metadatosBody').innerHTML =
                    `<div class="alert alert-danger m-3"><i class="fa-solid fa-triangle-exclamation me-2"></i>Error al obtener metadatos desde MongoDB.</div>`;
            });
    }

    // Restaura la tabla estática original y limpia los filtros
    function limpiarBuscador() {
        document.getElementById('inputBuscarMongo').value = '';
        document.getElementById('selectFiltroExt').value = '';
        document.getElementById('inputFiltroFecha').value = '';
        document.getElementById('cardResultadosMongo').classList.add('d-none');
        document.getElementById('cardOriginalRazor').classList.remove('d-none');
        document.getElementById('tbodyResultadosMongo').innerHTML = '';
        document.getElementById('paginacionMongo').innerHTML = '';
    }
</script>

<!-- MODAL PREMIUM DE METADATOS MONGODB -->
<div class="modal fade" id="modalMetadatosMongo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width: 560px;">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #1e3a5f 0%, #0369a1 100%); border-radius: 16px 16px 0 0;">
                <h5 class="modal-title fw-bold text-white" id="metadatosTitulo">
                    <i class="fa-solid fa-database me-2"></i>Metadatos del Documento
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="metadatosBody" style="max-height: 65vh; overflow-y: auto;">
                <!-- Renderizado dinámico vía JS -->
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center pb-3">
                <button type="button" class="btn fw-bold text-white px-5 py-2 shadow-sm" data-bs-dismiss="modal"
                        style="border-radius: 10px; background: linear-gradient(135deg, #1e3a5f, #0369a1);">
                    <i class="fa-solid fa-xmark me-1"></i> Cerrar
                </button>
            </div>
        </div>
    </div>
</div>