@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // 🌟 Recuperamos el usuario real logueado desde la sesión activa
    string userNameSession = HttpContextAccessor.HttpContext.Session.GetString("UserName") ?? "Usuario";


    // Convertimos a minúsculas de forma segura para hacer validaciones precisas de rol
    string userLower = userNameSession.ToLower();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QualityHub - Sistema Documental</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --sidebar-color: #2c3e50;
            --accent-color: #3498db;
        }

        body {
            background-color: #f8fafc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Estilo del Sidebar */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: var(--sidebar-color);
            position: fixed;
            color: white;
            padding-top: 20px;
            z-index: 1000;
        }

            .sidebar .nav-link {
                color: #bdc3c7;
                padding: 12px 25px;
                display: flex;
                align-items: center;
                gap: 10px;
                transition: 0.3s;
            }

                .sidebar .nav-link:hover {
                    background: #34495e;
                    color: white;
                }

                .sidebar .nav-link.active {
                    background: var(--accent-color);
                    color: white;
                    border-radius: 0 25px 25px 0;
                    margin-right: 15px;
                }

                .sidebar .nav-link i {
                    font-size: 1.2rem;
                }

        /* Contenedor Principal */
        .main-content {
            margin-left: 260px;
            padding: 0;
            min-height: 100vh;
        }

        .top-header {
            background: white;
            padding: 15px 30px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Estilos globales compartidos para la campanita */
        .bell-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            background-color: #ef4444;
            color: white;
            border-radius: 50%;
            padding: 2px 6px;
            font-size: 0.65rem;
            font-weight: bold;
            box-shadow: 0 0 0 2px white;
        }
    </style>
</head>
<body>
    @if (ViewData["Title"]?.ToString() != "Login")
    {
        // Detectamos en qué vista estamos actualmente
        var accionActual = ViewContext.RouteData.Values["action"]?.ToString();

        <div class="sidebar">
            <div class="px-4 mb-4">
                <h4 class="fw-bold text-white mb-0" style="font-size: 1.15rem;">
                    <i class="bi bi-shield-check text-info"></i> QualityHub
                </h4>
                <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Document System</small>
            </div>

            <nav class="nav flex-column">
                <div class="px-4 mt-2 mb-2 small text-uppercase text-muted" style="font-size: 0.75rem;">Módulos</div>

                <a class="nav-link @(accionActual == "Dashboard" ? "active" : "")" asp-controller="Home" asp-action="Dashboard">
                    <i class="bi bi-house-door"></i> Inicio
                </a>

                <div class="px-4 mt-4 mb-2 small text-uppercase text-muted" style="font-size: 0.75rem;">Operaciones</div>

                @if (HttpContextAccessor.HttpContext?.Session.GetInt32("UserRoleID") == 3)
                {
                    <a class="nav-link @(accionActual == "ControlAutorizaciones" ? "active" : "")" asp-controller="Home" asp-action="ControlAutorizaciones">
                        <i class="bi bi-shield-lock-fill"></i> Panel de Autorizaciones
                    </a>
                }
                else
                {
                    <a class="nav-link @(accionActual == "ControlDocumentos" || accionActual == "Creador" ? "active" : "")" asp-controller="Home" asp-action="ControlDocumentos">
                        <i class="bi bi-file-earmark-check"></i> Control de Documentos
                    </a>
                }
            </nav>
        </div>

        <div class="main-content">
            <header class="top-header">
                <span class="text-muted fw-semibold small text-uppercase" style="letter-spacing: 0.5px;">
                    @if (accionActual == "ControlDocumentos")
                    {
                        <text>Operaciones / Control de Documentos</text>
                    }
                    else if (accionActual == "Creador")
                    {
                        <text>Operaciones / Panel del Creador</text>
                    }
                    else if (accionActual == "ControlAutorizaciones")
                    {
                        <text>Operaciones / Panel de Autorizaciones</text>
                    }
                    else
                    {
                        <text>Dashboard / Inicio</text>
                    }
                </span>

                <div class="d-flex align-items-center gap-4">
                    <div class="position-relative" style="cursor: pointer;" onclick="verNotificacionesGlobales()">
                        <div class="bg-light p-2 rounded-circle d-flex align-items-center justify-content-center border" style="width: 40px; height: 40px;">
                            <i class="fa-regular fa-bell text-secondary fs-5"></i>
                            <span id="globalNotifCount" class="bell-badge" style="display:none;">0</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2 border-start ps-3">
                        <span class="small fw-bold text-dark">@userNameSession</span>
                        <img src="https://ui-avatars.com/api/?name=@System.Net.WebUtility.UrlEncode(userNameSession)&background=4e73df&color=ffffff&bold=true" class="rounded-circle shadow-sm" width="35" height="35">

                        <!-- BOTÓN CERRAR SESIÓN -->
                        <a href="@Url.Action("CerrarSesion", "Home")" class="btn btn-sm btn-outline-danger ms-3 fw-bold" style="border-radius: 8px;">
                            <i class="bi bi-box-arrow-right me-1"></i> Cerrar Sesión
                        </a>
                    </div>
                </div>
            </header>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let historialGlobal = JSON.parse(sessionStorage.getItem('historialNotif')) || [];
        let contadorGlobal = parseInt(sessionStorage.getItem('contadorNotif')) || 0;

        @if (TempData["NotificacionCampana"] != null)
        {
                        <text>
                            historialGlobal.push("@Html.Raw(TempData["NotificacionCampana"])");
                            contadorGlobal += 1;
                            sessionStorage.setItem('contadorNotif', contadorGlobal.toString());
                            sessionStorage.setItem('historialNotif', JSON.stringify(historialGlobal));
                        </text>
        }

        document.addEventListener("DOMContentLoaded", function () {
            renderizarBadgeGlobal();
        });

        function renderizarBadgeGlobal() {
            const badge = document.getElementById('globalNotifCount');
            if (badge) {
                if (contadorGlobal > 0) {
                    badge.innerText = contadorGlobal;
                    badge.style.display = 'block';
                } else {
                    badge.style.display = 'none';
                }
            }
        }

        function verNotificacionesGlobales() {
            if (contadorGlobal === 0) {
                Swal.fire({
                    title: 'Buzón Vacío',
                    text: 'No tienes alertas ni operaciones sin leer.',
                    icon: 'question',
                    confirmButtonColor: '#475569'
                });
                return;
            }

            let listaHtml = '<ul class="text-start list-group list-group-flush" style="max-height: 250px; overflow-y: auto;">';
            historialGlobal.forEach(notif => {
                listaHtml += `<li class="list-group-item small border-bottom py-2"><i class="fa-solid fa-circle-info text-primary me-2"></i>${notif}</li>`;
            });
            listaHtml += '</ul>';

            Swal.fire({
                title: 'Historial de Operaciones',
                html: listaHtml,
                icon: 'info',
                confirmButtonText: 'Marcar como leídas',
                confirmButtonColor: '#3b82f6'
            }).then((result) => {
                if (result.isConfirmed) {
                    contadorGlobal = 0;
                    historialGlobal = [];
                    sessionStorage.setItem('contadorNotif', '0');
                    sessionStorage.setItem('historialNotif', JSON.stringify([]));
                    renderizarBadgeGlobal();

                    const localBadge = document.getElementById('notifCount');
                    if (localBadge) localBadge.style.display = 'none';
                }
            });
        }
    </script>

    @* 🌟 Renderizado de secciones de scripts específicas de las vistas hijas (¡Solución al Error!) *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>